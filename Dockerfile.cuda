# syntax=docker/dockerfile:1
# CUDA GPU build (Candle CUDA + ONNX Runtime CUDA EP for BERT/HuBERT)

# ============================================================
# Builder stage — CUDA toolkit + Rust toolchain
# ============================================================
FROM nvidia/cuda:13.2.0-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

# GPU compute capability — override with: docker build --build-arg CUDA_COMPUTE_CAP=86
# Common: 75=RTX20xx, 80=A100, 86=RTX30xx, 89=RTX40xx, 90=H100
ARG CUDA_COMPUTE_CAP=89
ENV CUDA_COMPUTE_CAP=${CUDA_COMPUTE_CAP}

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential g++ pkg-config libssl-dev ca-certificates libsoxr-dev \
    && rm -rf /var/lib/apt/lists/* \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && ln -s /root/.cargo/bin/cargo /usr/local/bin/cargo \
    && ln -s /root/.cargo/bin/rustc /usr/local/bin/rustc

ENV CUDA_HOME=/usr/local/cuda
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}

# Copy entire project (.dockerignore excludes target/, .git/, models/, etc.)
# Includes .cargo/config.toml which redirects crate downloads to rsproxy.cn (CN mirror)
COPY . .

# ORT_LIB_LOCATION: skip cdn.pyke.io download, use pre-bundled CUDA 13 libonnxruntime.a + provider .so.
# ORT CUDA EP requires cuDNN (libcudnn.so.9) which is not included here to keep image size small.
# BERT/HuBERT preprocessing runs on ORT CPU EP (fast, runs once); GPT+SoVITS uses Candle CUDA.
ENV ORT_LIB_LOCATION=/app/docker-ort-libs/cuda

# Build binary — cuda enables Candle CUDA backend; onnx enables BERT/HuBERT via ort
RUN cargo build --release --locked --features http-api,cuda,onnx && \
    cp target/release/gpt-sovits /app/gpt-sovits && \
    # ort statically links libonnxruntime.a but loads CUDA EP and shared provider via dlopen at runtime.
    # Use the pre-bundled .so files from docker-ort-libs/cuda/ (same ones used for linking).
    cp -L docker-ort-libs/cuda/libonnxruntime_providers_shared.so /app/ && \
    cp -L docker-ort-libs/cuda/libonnxruntime_providers_cuda.so /app/

# ============================================================
# Runtime stage — minimal CUDA runtime
# ============================================================
FROM nvidia/cuda:13.2.0-runtime-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# libcublas/libcurand already included in nvidia/cuda:12.6.0-runtime base image
RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 ca-certificates libsoxr0 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/gpt-sovits /usr/local/bin/gpt-sovits
COPY --from=builder /app/libonnxruntime_providers_shared.so /usr/local/lib/
COPY --from=builder /app/libonnxruntime_providers_cuda.so /usr/local/lib/

RUN ldconfig && \
    mkdir -p /app && \
    ln -s /usr/local/lib/libonnxruntime_providers_shared.so /app/libonnxruntime_providers_shared.so && \
    ln -s /usr/local/lib/libonnxruntime_providers_cuda.so /app/libonnxruntime_providers_cuda.so

RUN mkdir -p /app/models

WORKDIR /app

ENTRYPOINT ["gpt-sovits"]
CMD ["--help"]
