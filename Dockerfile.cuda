# syntax=docker/dockerfile:1
# CUDA GPU build (Candle CUDA — no ONNX Runtime dependency)

# ============================================================
# Builder stage — CUDA toolkit + Rust toolchain
# ============================================================
FROM nvidia/cuda:13.2.0-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

# GPU compute capability must match the target GPU architecture.
# Common: 75=RTX20xx, 80=A100, 86=RTX30xx, 89=RTX40xx, 90=H100
ARG CUDA_COMPUTE_CAP=89
ENV CUDA_COMPUTE_CAP=${CUDA_COMPUTE_CAP}

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential clang g++ pkg-config libssl-dev ca-certificates libsoxr-dev \
    && rm -rf /var/lib/apt/lists/* \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && ln -s /root/.cargo/bin/cargo /usr/local/bin/cargo \
    && ln -s /root/.cargo/bin/rustc /usr/local/bin/rustc

ENV CUDA_HOME=/usr/local/cuda
ENV PATH=${CUDA_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${LD_LIBRARY_PATH}

# Copy entire project (.dockerignore excludes target/, .git/, models/, etc.)
COPY . .

# Build binary — cuda enables Candle CUDA; BERT/HuBERT use native Candle (no ORT)
RUN cargo build --release --locked --features http-api,cuda && \
    cp target/release/gpt-sovits /app/gpt-sovits

# ============================================================
# Runtime stage — ubuntu:24.04 + only required CUDA libs
# ============================================================
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
# Required for nvidia-container-runtime to inject libcuda.so.1 from host driver
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 ca-certificates libsoxr0 libstdc++6 libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy only the CUDA libs our binary actually links against (ldd verified)
COPY --from=builder /usr/local/cuda/lib64/libcudart.so.13.2.51    /usr/local/lib/
COPY --from=builder /usr/local/cuda/lib64/libcublas.so.13.3.0.5   /usr/local/lib/
COPY --from=builder /usr/local/cuda/lib64/libcublasLt.so.13.3.0.5 /usr/local/lib/
COPY --from=builder /usr/local/cuda/lib64/libcurand.so.10.4.2.51  /usr/local/lib/

COPY --from=builder /app/gpt-sovits /usr/local/bin/gpt-sovits

RUN ldconfig && mkdir -p /app/models

WORKDIR /app

ENTRYPOINT ["gpt-sovits"]
CMD ["--help"]
