# Copy to .env and adjust paths for your PC or NAS.

# Host folders mounted into the container.
MODELS_DIR=./models
VOICES_DIR=./voices
OUTPUTS_DIR=./outputs

# HTTP server.
GPT_SOVITS_PORT=9880
# Includes the default model pair. Raise only when the device has enough RAM/VRAM.
MAX_CACHED_PIPELINES=2

# Model files inside the container. Change these if your filenames differ.
GPT_MODEL=/app/models/gpt-model.safetensors
SOVITS_MODEL=/app/models/sovits-model.safetensors
BERT_MODEL=/app/models/bert/bert.safetensors
HUBERT_MODEL=/app/models/hubert/hubert.safetensors

# Published image tags. CPU: latest. CUDA:
# latest-cuda-sm75 (RTX 20), sm86 (RTX 30), sm89 (RTX 40), sm90 (H100).
GPT_SOVITS_IMAGE_TAG=latest
CUDA_IMAGE_TAG=latest-cuda-sm89
