# Copy to .env and adjust paths for your PC or NAS.

# Host folders mounted into the container.
MODELS_DIR=./models
VOICES_DIR=./voices
OUTPUTS_DIR=./outputs

# HTTP server.
GPT_SOVITS_PORT=9880

# Model files inside the container.
GPT_MODEL=/app/models/gpt-model.safetensors
SOVITS_MODEL=/app/models/sovits-model.safetensors

# The loader supports either flat or nested BERT/HuBERT layouts.
BERT_MODEL=/app/models/bert.safetensors
HUBERT_MODEL=/app/models/hubert.safetensors

# CUDA build only. Common values:
# 75=RTX20xx, 80=A100, 86=RTX30xx, 89=RTX40xx, 90=H100.
CUDA_COMPUTE_CAP=89
